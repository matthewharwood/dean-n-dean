# Project-level TOOLING secrets (not app/client env — that lives in apps/web/.env).
# Copy this file to `.env.local` (gitignored) and fill real values THERE.
# NEVER put a real secret in this committed file.
#
# ElevenLabs API key — used by the ElevenLabs MCP + `/sfx` audio workflow (e.g.
# generating the phonics clips in docs/phonics/AUDIO-MANIFEST.md). Tooling/MCP
# only; never a VITE_/client var. See AGENTS.md "API keys & local secrets".
ELEVENLABS_API_KEY=

# Tripo3D API key — 3D-asset generation tooling. Tooling-only; never a VITE_/client
# var. See AGENTS.md "API keys & local secrets".
TRIPO3D_API_KEY=
