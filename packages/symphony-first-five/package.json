{
  "name": "@dean-stack/symphony-first-five",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsgo --noEmit && bun build ./src/index.ts --outdir ./dist --target bun --format esm --external @dean-stack/schemas --external zod",
    "typecheck": "tsgo --noEmit",
    "test:unit": "bun test src"
  },
  "dependencies": {
    "@dean-stack/schemas": "workspace:*",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@dean-stack/tsconfig": "workspace:*",
    "@types/bun": "^1.3.0",
    "@typescript/native-preview": "^7.0.0-dev.20260426.1"
  }
}
